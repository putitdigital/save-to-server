{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flowit",
  "version": "0.1.16",
  "identifier": "com.flowit.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 980,
        "height": 760,
        "resizable": true,
        "theme": "Dark",
        "backgroundColor": "#091018"
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/putitdigital/save-to-server/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU4MDdGQTA2MTMwRkMwRDQKUldUVXdBOFRCdm9INkR1cDhUWS9KMGJsd01jQjlFZ1NVVjZIWEtiT2Uvd0RLT2tvdUxhN0U5N0EK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../run.sh",
      "../../ignore",
      "../../easy.sh",
      "../../README.md",
      "../../scripts",
      "../../launchd",
      "../../logs",
      "../../.syncignore"
    ]
  }
}
