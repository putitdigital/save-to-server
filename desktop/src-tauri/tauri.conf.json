{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flowit",
  "version": "0.1.0",
  "identifier": "com.flowit.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flowit",
        "width": 980,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../run.sh",
      "../../ignore",
      "../../easy.sh",
      "../../scripts",
      "../../logs",
      "../../.syncignore"
    ]
  }
}
