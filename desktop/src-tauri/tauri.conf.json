{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flowit",
  "version": "0.1.0",
  "identifier": "com.flowit.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flowit",
        "width": 980,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/putitdigital/save-to-server/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../run.sh",
      "../../ignore",
      "../../easy.sh",
      "../../README.md",
      "../../scripts",
      "../../launchd",
      "../../logs",
      "../../.syncignore"
    ]
  }
}
